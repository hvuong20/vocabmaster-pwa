# Tạo keys bằng: node generate-keys.js
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here

# Email liên hệ (dùng trong VAPID header)
VAPID_EMAIL=mailto:your@email.com

# Port (Render.com tự set, để nguyên)
PORT=3000

# URL của server này trên Render.com (để self-ping tránh sleep)
# Ví dụ: https://vocabmaster-push.onrender.com
RENDER_EXTERNAL_URL=
